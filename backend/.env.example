# ============================================================
# Malabar Spice Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# ============================================================

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/malabar-spice

# Port the server listens on (Render sets this automatically)
PORT=5000

# Secret key for signing JWT tokens — use a long random string
JWT_SECRET=replace_with_a_long_random_secret_string

# Admin panel credentials
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password

# Frontend URL for CORS (your Netlify domain)
CORS_ORIGIN=https://your-frontend.netlify.app
